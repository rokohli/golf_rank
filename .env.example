APP_ENV=development
ALLOW_DEVELOPMENT_IDENTITY=true
DATABASE_URL=postgresql+psycopg://golf_rank:golf_rank@db:5432/golf_rank
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_KEY_SALT=replace-with-at-least-32-random-characters
TRUSTED_CLIENT_IP_HEADER=
ALLOWED_HOSTS=localhost,127.0.0.1
MAX_REQUEST_BODY_BYTES=1048576
# Optional HTTPS receiver for privacy-safe operational alert JSON. Without it,
# threshold crossings are still emitted as critical structured logs.
OPERATIONS_ALERT_WEBHOOK_URL=
OPERATIONS_ALERT_WEBHOOK_TIMEOUT_SECONDS=2
RATE_LIMIT_ALERT_WINDOW_SECONDS=300
RATE_LIMIT_BACKEND_FAILURE_ALERT_THRESHOLD=3
RATE_LIMIT_DENIAL_ALERT_THRESHOLD=50
RATE_LIMIT_IDENTITY_ALERT_THRESHOLD=10
RATE_LIMIT_ALERT_COOLDOWN_SECONDS=900
RATE_LIMIT_ALERT_MAX_TRACKED_KEYS=10000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Use "development" for immediate no-account local testing.
# Use "admin-development" to show the get started screen and continue as a local admin.
# Use "clerk" when testing real auth.
EXPO_PUBLIC_AUTH_MODE=development
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Issuer and JWKS URL are required when APP_ENV is not development.
CLERK_ISSUER=
CLERK_JWKS_URL=
# Optional during rollout. When enabled, this must match the static aud claim
# configured under Clerk Dashboard > Sessions > Customize session token.
CLERK_AUDIENCE=
